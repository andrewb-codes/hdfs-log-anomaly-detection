services:
  redis:
    image: redis:7.4-alpine
    command:
      - redis-server
      - --appendonly
      - "no"
      - --save
      - ""
      - --maxmemory
      - 128mb
      - --maxmemory-policy
      - volatile-ttl
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s
    networks:
      - default
    restart: unless-stopped

  postgres:
    image: postgres:17
    environment:
      POSTGRES_DB: "${POSTGRES_DB:?POSTGRES_DB is required}"
      POSTGRES_USER: "${POSTGRES_USER:?POSTGRES_USER is required}"
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD:?POSTGRES_PASSWORD is required}"
    volumes:
      - hdfs_anomaly_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s
    networks:
      - default
    restart: unless-stopped

  api:
    image: "{{ api_image_ref }}"
    env_file:
      - .env
    volumes:
      - ./artifacts:/app/artifacts
      - ./reports:/app/reports
      - ./configs:/app/configs
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=2)"
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s
    networks:
      - default
    restart: unless-stopped

  frontend:
    image: "{{ frontend_image_ref }}"
    environment:
      STREAMLIT_API_URL: "http://api:8000"
    expose:
      - "8501"
    depends_on:
      api:
        condition: service_healthy
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8501/_stcore/health', timeout=2)"
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s
    networks:
      {{ docker_public_network }}:
        aliases:
          - {{ frontend_network_alias }}
      default:
    restart: unless-stopped

networks:
  {{ docker_public_network }}:
    external: true

volumes:
  hdfs_anomaly_data:
