# FastAPI database connection used by the API and Alembic.
DATABASE_URL=postgresql+asyncpg://anomaly_user:anomaly_password@localhost:5432/anomaly_test

# JWT secret used by the FastAPI authentication flow.
JWT_SECRET=replace-with-a-long-random-secret

# CORS origins used by API tests.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
