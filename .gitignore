# Python bytecode and native extensions
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments and local environment files
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Packaging and build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test, lint, type-check, and coverage outputs
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.uv-cache/
.uv/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit.xml
test-results/

# Jupyter and IPython state
.ipynb_checkpoints/
profile_default/
ipython_config.py

# IDE, editor, and OS files
.idea/
.vscode/
.DS_Store
tempCodeRunnerFile.py

# Logs and local runtime storage
*.log
*.pid
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
.matplotlib_cache/

# Local Docker and Streamlit overrides
docker-compose.override.yml
.streamlit/secrets.toml

# Project data
# Keep placeholders/documentation, but never commit LogHub data.
data/*
!data/README.md
!data/.gitkeep

# Model artifacts and experiment binaries
artifacts/*
!artifacts/README.md
!artifacts/.gitkeep
*.pt
*.pth
*.ckpt
*.pkl
*.joblib
*.onnx
*.bin

# Large/raw tabular exports
*.parquet
*.feather
*.npz
*.npy

# Generated notebook outputs that are too large for the repository.
# Small summary tables and figures under reports/ can be committed selectively.
reports/eda/tables/timeinterval_stats_per_trace.csv
reports/tabular_baselines/tables/scores_*.csv
reports/lstm_one_step/*/tables/scores_*.csv
reports/lstm_many_to_many/*/tables/scores_*.csv

# Local Ansible deployment secrets
deploy/ansible/inventory.ini
deploy/ansible/group_vars/*.vault.yml
!deploy/ansible/group_vars/*.vault.yml.example
deploy/ansible/group_vars/**/vault.yml
!deploy/ansible/group_vars/**/vault.yml.example
