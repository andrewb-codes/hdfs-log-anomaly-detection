# Copy this file to .env for local development.

# FastAPI database connection used by the API and Alembic.
DATABASE_URL=postgresql+asyncpg://anomaly_user:anomaly_password@postgres:5432/anomaly

# JWT secret used by the FastAPI authentication flow.
JWT_SECRET=replace-with-a-long-random-secret

# Bootstrap admin user created by the seed script.
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=replace-with-admin-email
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-password

# Demo user created by the seed script.
DEMO_USER_ENABLED=true
DEMO_EMAIL=replace-with-demo-email
DEMO_PASSWORD=replace-with-a-long-random-password

# Docker Compose published ports.
STREAMLIT_PORT=8501

# Streamlit API target for running the frontend outside Docker Compose.
STREAMLIT_API_URL=http://127.0.0.1:8000

# PostgreSQL container settings used by docker-compose.
POSTGRES_DB=anomaly
POSTGRES_USER=anomaly_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_PORT=5434
