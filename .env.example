# Copy this file to .env for local development.

# Admin credentials used by the FastAPI authentication flow.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT secret used by the FastAPI authentication flow.
JWT_SECRET=change-me

# Used by Streamlit to call the FastAPI backend.
STREAMLIT_API_URL=http://api:8000

# Docker Compose published ports.
STREAMLIT_PORT=8501
