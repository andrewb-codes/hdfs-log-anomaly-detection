# Copy this file to .env for local development.

# Admin credentials used by the FastAPI authentication flow.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT settings used by the FastAPI authentication flow.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=60

# Used by Streamlit when it is started locally with `uv run streamlit ...`.
STREAMLIT_API_URL=http://127.0.0.1:8000

# Docker Compose published ports.
STREAMLIT_PORT=8501
